# Copy to .env and fill in locally. Never commit .env.

# OpenAI — required for the local demo script (npm run demo), not for CI
OPENAI_API_KEY=your-openai-api-key-here

# Path to the operator's real Vault (Obsidian). Leave unset to use the committed Demo vault.
# VAULT_PATH=/absolute/path/to/your/obsidian-vault

# Run log directory (gitignored). Defaults to ./.logs/
# LOG_DIR=./.logs/

# Log level: debug | info | warn | error
LOG_LEVEL=info
