# Copy to .env and fill in locally. Never commit .env.

# OpenAI — required for the local demo script (npm run demo) and spec agent (npm run agent:build), not for CI
OPENAI_API_KEY=your-openai-api-key-here

# Cursor — required for agent:build coding executor (npm run agent:build), not for CI
CURSOR_API_KEY=your-cursor-api-key-here

# Coding executor mode: durable (default) | one-shot
# CODING_EXECUTOR_MODE=durable

# Path to the operator's real Vault (Obsidian). Leave unset to use the committed Demo vault.
# VAULT_PATH=/absolute/path/to/your/obsidian-vault

# PRD and planning docs directory (gitignored runtime state is separate). Defaults to ./docs/prds/
# PRDS_DIR=./docs/prds/

# Work-item manifest directory (gitignored). Defaults to ./.mastra/state/
# STATE_DIR=./.mastra/state/

# Run log directory (gitignored). Defaults to ./.logs/
# LOG_DIR=./.logs/

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Observability verbosity: silent | minimal | standard | verbose | debug
# OBSERVABILITY_LEVEL=standard

# Optional: override reasoning-tier model for Code Reviewer (defaults to config/default.json defaultReviewModel)
# DEFAULT_REVIEW_MODEL=openai/gpt-4o

# Phase 7 authoring: autonomous proposal cap (default 3) and enable flag (default true)
# AUTHORING_CAP=3
# AUTHORING_PROPOSALS_ENABLED=true
